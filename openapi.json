{
  "openapi": "3.1.0",
  "info": {
    "title": "Resume AI Assistant API",
    "description": "A small Retrieval-Augmented Generation (RAG) system for resumes.\n\n- **Resume Q&A** — ask questions about an uploaded resume (embeddings + cosine-similarity relevance check + Qwen3 via Ollama).\n- **Job Matcher** — match a job description against a pool of resumes.\n\nBuilt with FastAPI, sentence-transformers (all-MiniLM-L6-v2), and Ollama (Qwen3).",
    "contact": {
      "name": "Zaid bin Mukhaylib"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/upload": {
      "post": {
        "tags": [
          "Resume Q&A"
        ],
        "summary": "Upload a resume",
        "description": "Upload a **PDF resume**, save it on the server, and build the RAG pipeline\n(embeddings + retriever) used by the `/ask` endpoint.\n\nUploading a new file replaces the resume currently used for Q&A.",
        "operationId": "upload_resume_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_resume_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or unreadable PDF",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    },
    "/ask": {
      "post": {
        "tags": [
          "Resume Q&A"
        ],
        "summary": "Ask a question about the resume",
        "description": "Answer a natural-language question about the currently uploaded resume.\n\nThe question is first checked for relevance using cosine similarity; if it is\nout of scope, a fixed message is returned without calling the language model.",
        "operationId": "ask_question_ask_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Question"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnswerResponse"
                }
              }
            }
          },
          "400": {
            "description": "No resume uploaded or empty question",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Answer generation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    },
    "/match/upload": {
      "post": {
        "tags": [
          "Job Matcher"
        ],
        "summary": "Upload resumes for matching",
        "description": "Upload **one or more PDF resumes** and add them to the shared resume pool used\nby the `/match` endpoint. Non-PDF files are silently skipped.",
        "operationId": "upload_resumes_for_matching_match_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_resumes_for_matching_match_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "No valid PDF files uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    },
    "/match": {
      "post": {
        "tags": [
          "Job Matcher"
        ],
        "summary": "Find the best-matching resume",
        "description": "Compare a **job description** against every resume in the pool and return the\nsingle best-matching resume, based on embedding cosine similarity.",
        "operationId": "match_job_match_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobDescription"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Empty description or no resumes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "AnswerResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer",
            "examples": [
              "The candidate knows Python and R."
            ]
          }
        },
        "type": "object",
        "required": [
          "answer"
        ],
        "title": "AnswerResponse"
      },
      "Body_upload_resume_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File",
            "description": "A PDF resume file."
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_resume_upload_post"
      },
      "Body_upload_resumes_for_matching_match_upload_post": {
        "properties": {
          "files": {
            "items": {
              "type": "string",
              "contentMediaType": "application/octet-stream"
            },
            "type": "array",
            "title": "Files",
            "description": "One or more PDF resume files."
          }
        },
        "type": "object",
        "required": [
          "files"
        ],
        "title": "Body_upload_resumes_for_matching_match_upload_post"
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "type": "string",
            "title": "Detail",
            "examples": [
              "Please upload a resume first."
            ]
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ErrorResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "JobDescription": {
        "properties": {
          "job_description": {
            "type": "string",
            "title": "Job Description",
            "description": "A description of the job or the skills you are looking for.",
            "examples": [
              "Looking for a candidate with strong Python and data science skills"
            ]
          }
        },
        "type": "object",
        "required": [
          "job_description"
        ],
        "title": "JobDescription"
      },
      "MatchResponse": {
        "properties": {
          "filename": {
            "type": "string",
            "title": "Filename",
            "examples": [
              "resume1.pdf"
            ]
          },
          "resume_text": {
            "type": "string",
            "title": "Resume Text",
            "examples": [
              "ZAID BIN MUKHAYLIB\nRiyadh, Saudi Arabia ..."
            ]
          }
        },
        "type": "object",
        "required": [
          "filename",
          "resume_text"
        ],
        "title": "MatchResponse"
      },
      "MatchUploadResponse": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message",
            "examples": [
              "Uploaded 2 resume(s) for matching."
            ]
          },
          "filenames": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Filenames",
            "examples": [
              [
                "resume1.pdf",
                "resume2.pdf"
              ]
            ]
          }
        },
        "type": "object",
        "required": [
          "message",
          "filenames"
        ],
        "title": "MatchUploadResponse"
      },
      "Question": {
        "properties": {
          "question": {
            "type": "string",
            "title": "Question",
            "description": "The question to ask about the uploaded resume.",
            "examples": [
              "What programming languages does the candidate know?"
            ]
          }
        },
        "type": "object",
        "required": [
          "question"
        ],
        "title": "Question"
      },
      "UploadResponse": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message",
            "examples": [
              "Resume 'resume.pdf' uploaded and indexed successfully."
            ]
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "UploadResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "APIKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "tags": [
    {
      "name": "Resume Q&A",
      "description": "Upload a single resume and ask natural-language questions about it."
    },
    {
      "name": "Job Matcher",
      "description": "Upload multiple resumes and find the best match for a job description."
    }
  ]
}